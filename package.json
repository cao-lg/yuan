{
	"name": "phaser3-parcel-template",
	"version": "1.0.0",
	"description": "A template project for Phaser3 using Parceljs",
	"scripts": {
		"dev": "vite",
		"build": "vite build && npx shx cp -r public/* dist/",
		"preview": "vite preview",
		"test": "echo \"Error: no test specified\" && exit 1"
	},
	"author": "supertommy",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/ourcade/phaser3-parcel-template.git"
	},
	"homepage": "https://github.com/ourcade/phaser3-parcel-template",
	"devDependencies": {
		"@types/node": "^13.13.5",
		"@vitejs/plugin-legacy": "^8.0.1",
		"minimist": ">=1.2.2",
		"parcel-plugin-clean-easy": "^1.0.2",
		"parcel-plugin-static-files-copy": "^2.2.1",
		"parcel-reporter-static-files-copy": "^1.5.3",
		"shx": "^0.4.0",
		"terser": "^5.46.1",
		"typescript": "^3.8.3",
		"vite": "^8.0.8"
	},
	"dependencies": {
		"@mikewesthad/dungeon": "^2.0.1",
		"phaser": "^3.22.0",
		"phaser-virtual-joystick": "^0.3.1"
